# ─────────────────────────────────────────
# App
# ─────────────────────────────────────────
APP_NAME=Racketek Outlet
APP_VERSION=1.0.0
DEBUG=False

SECRET_KEY=REPLACE_WITH_REAL_SECRET   # generate properly
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─────────────────────────────────────────
# Database
# ─────────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/racketek_db

# ─────────────────────────────────────────
# Redis
# ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─────────────────────────────────────────
# Razorpay
# ─────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxx

# ─────────────────────────────────────────
# Cloudinary
# ─────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=xxxx
CLOUDINARY_API_KEY=xxxx
CLOUDINARY_API_SECRET=xxxx

# ─────────────────────────────────────────
# Google OAuth
# ─────────────────────────────────────────
GOOGLE_CLIENT_ID=xxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxx

# ─────────────────────────────────────────
# Email (Gmail - DEV ONLY)
# ─────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=racketek.auth@gmail.com
SMTP_PASSWORD=your_app_password

EMAILS_FROM_EMAIL=racketek.auth@gmail.com
EMAILS_FROM_NAME=Racketek Outlet

# ─────────────────────────────────────────
# OpenAI
# ─────────────────────────────────────────
OPENAI_API_KEY=sk-xxxx

# ─────────────────────────────────────────
# Celery
# ─────────────────────────────────────────
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ─────────────────────────────────────────
# CORS
# ─────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:3000,https://racketoutlet.in

# ─────────────────────────────────────────
# Frontend URL
# ─────────────────────────────────────────
FRONTEND_URL=http://localhost:3000